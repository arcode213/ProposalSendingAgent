# Copy to .env and fill in real values. Safe to commit (no secrets).
# On Vercel, set these under Project → Settings → Environment Variables instead.

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key
FROM_EMAIL=you@yourdomain.com
REPLY_TO=you@yourdomain.com
SENDER_NAME=RoamDigi
SENDER_TITLE=Partner Program

# Admin login. Generate a hash with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('YOUR_PASSWORD'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt:...replace-with-your-own-hash...

# Session signing key. Generate with:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-hex-string
